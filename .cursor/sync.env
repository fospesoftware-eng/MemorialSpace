# Cursor → GitHub auto-sync (see .cursor/hooks/sync-to-github.sh)
AUTO_PUSH=1
DEBOUNCE_SEC=20
# Push to the branch you have checked out. Block accidental pushes to main:
ALLOW_MAIN_SYNC=0
# Replit-owned paths — never included in Cursor auto-sync commits
REPLIT_EXCLUDE=".replit .replitignore replit.md"
